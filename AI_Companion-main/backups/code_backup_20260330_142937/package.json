{
  "name": "ai-companion-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "build": "npm run build --workspace backend && npm run build --workspace frontend",
    "db:generate": "npm run prisma:generate --workspace backend",
    "db:migrate": "npm run db:migrate --workspace backend",
    "db:bootstrap": "npm run db:bootstrap --workspace backend",
    "smoke": "npm run smoke --workspace backend",
    "verify:backend": "npm run verify --workspace backend"
  },
  "devDependencies": {
    "concurrently": "latest"
  }
}
