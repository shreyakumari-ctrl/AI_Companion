generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

model UserProfile {
  id             String   @id @default(cuid())
  name           String?
  tonePreference String   @default("friendly")
  mood           String   @default("curious")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
